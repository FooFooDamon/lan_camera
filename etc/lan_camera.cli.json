{
    "logger": {
        "level": "info"
    },

    "role": {
        "type": "client",
        "name": "lanc-desktop"
    },

    "network": {
        "connect": {
            "ip": "192.168.11.11",
            "port": 59394,
            "heartbeat_msecs": 500,
            "poll_timeout_msecs": 3500
        }
    },

    "save": {
        "enabled": false,
        "dir": "/opt/lan_camera/save",
        "ramfs": {
            "enabled": true,
            "path": "/tmp"
        },
        "delays_flushing": false,
        "min_duration_secs": 10,
        "backup_history_days": 90,
        "sync": {
            "ip": "192.168.11.11",
            "port": 873,
            "user": "lanc",
            "password": "file:///usr/local/etc/rsync-lanc.pswd",
            "common_options": "-arvz --delete --perms --links --hard-links --times -P",
            "ssh_example": "rsync --rsh='sshpass -p ${password} ssh -l ${user}' ${common-options} --port={port} ${user}@${ip}:${dir}/server ${dir}/",
            "auth_rsync_example": "rsync --password-file=/usr/local/etc/rsync.pswd ${common-options} rsync://${user}@${ip}:{port}/lan_camera ${dir}/server",
            "anon_rsync_example": "rsync ${common-options} rsync://${ip}:{port}/lan_camera ${dir}/server"
        }
    },

    "audio": {
        "record_start": "/opt/lan_camera/etc/audio/record-start.wav",
        "record_end": "/opt/lan_camera/etc/audio/record-end.wav",
        "volume": 0.8
    },

    "player": {
        "canvas_sizes": [
            [ 640, 480 ],
            [ 720, 540 ],
            [ 800, 600 ],
            [ 960, 720 ],
            [ 1280, 720 ],
            [ 1280, 960 ]
        ],
        "which_size": 1,
        "opengl": {
            "version": "460 core",
            "profile": "core"
        }
    }
}

